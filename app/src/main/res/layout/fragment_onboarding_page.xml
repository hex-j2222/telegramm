<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:gravity="center"
    android:padding="32dp" android:background="@color/bg_primary">

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieAnim"
        android:layout_width="240dp" android:layout_height="240dp"
        app:lottie_autoPlay="true" app:lottie_loop="true"
        android:layout_marginBottom="32dp"/>

    <TextView android:id="@+id/tvTitle"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:gravity="center" android:textSize="24sp"
        android:fontFamily="@font/inter_bold" android:textColor="@color/text_primary"
        android:layout_marginBottom="16dp" android:lineSpacingMultiplier="1.2"/>

    <TextView android:id="@+id/tvDescription"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:gravity="center" android:textSize="15sp"
        android:textColor="@color/text_secondary" android:lineSpacingMultiplier="1.6"/>
</LinearLayout>
