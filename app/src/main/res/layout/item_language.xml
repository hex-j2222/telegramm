<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp" app:cardBackgroundColor="@color/surface_card"
    app:strokeColor="@color/stroke_subtle" app:strokeWidth="1dp" app:cardElevation="0dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingHorizontal="16dp">
        <TextView android:id="@+id/tvNativeName"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textSize="16sp"
            android:fontFamily="@font/inter_semibold" android:textColor="@color/text_primary"/>
        <TextView android:id="@+id/tvEnglishName"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="13sp" android:textColor="@color/text_secondary"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
